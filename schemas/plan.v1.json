{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan.v1",
  "title": "Plan v1",
  "type": "object",
  "required": ["schema_version", "plan_id", "goal", "steps", "caps"],
  "properties": {
    "schema_version": {"const": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "goal":    {"type": "string", "minLength": 1},
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "agent", "inputs", "validate", "depends_on"],
        "properties": {
          "id":         {"type": "string", "pattern": "^s[0-9]+$"},
          "agent":      {"type": "string", "minLength": 1},
          "inputs":     {"type": "object"},
          "validate":   {"type": "boolean"},
          "depends_on": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": false
      }
    },
    "caps": {
      "type": "object",
      "required": ["retries_per_step", "reroutes", "replans"],
      "properties": {
        "retries_per_step": {"type": "integer", "minimum": 0},
        "reroutes":         {"type": "integer", "minimum": 0},
        "replans":          {"type": "integer", "minimum": 0}
      }
    }
  },
  "additionalProperties": false
}
