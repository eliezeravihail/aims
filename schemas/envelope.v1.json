{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "envelope.v1",
  "title": "Agent Result Envelope v1",
  "type": "object",
  "required": ["schema_version", "ok"],
  "properties": {
    "schema_version": {"const": 1},
    "ok": {"type": "boolean"},
    "outputs": {"type": "object"},
    "retry": {
      "type": "object",
      "required": ["reason"],
      "properties": {
        "reason": {"type": "string"},
        "hint": {"type": "string"}
      },
      "additionalProperties": false
    },
    "abort": {
      "type": "object",
      "required": ["reason"],
      "properties": {"reason": {"type": "string"}},
      "additionalProperties": false
    },
    "advisory": {"type": "string"},
    "meta": {"type": "object"}
  },
  "oneOf": [
    {"required": ["outputs"], "properties": {"ok": {"const": true}}},
    {"required": ["retry"],   "properties": {"ok": {"const": false}}},
    {"required": ["abort"],   "properties": {"ok": {"const": false}}}
  ],
  "additionalProperties": false
}
