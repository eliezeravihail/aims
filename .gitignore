# Project-context cache (per-checkout, written by /snapshot)
.claude-context.md

# Planning lock (set by /plan during read-only phase)
.claude/.planning-lock

# Memory subsystem runtime queue (written by post-edit-marker hook,
# drained by stop-consolidate)
docs/memory/_inbox.md

# Memory consolidation throttle state (written by stop-consolidate)
.claude/memory/.last-consolidated

# Prompt-submit per-session injection state (ADR-0016 dedup ledger)
.claude/memory/.injected-*

# Pre-write per-session planning-note marker (ADR-0020 inject-once)
.claude/.aims-plan-note-*

# Memory-node sidecars (ADR-0024): `.lock` strict consolidation mutex
# (stop-consolidate.sh); `.marker` advisory edit-marker (post-edit-marker.sh).
# Two protocols, one leaf, distinct suffixes.
docs/memory/**/*.lock
docs/memory/**/*.marker

# Editor / OS noise
.DS_Store
*.swp
